  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/supertest": "^6",
    "esbuild": "^0.27.3",
    "pino-pretty": "^13",
    "supertest": "^7",
    "tsx": "^4.19.0",
